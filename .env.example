# Copy this to .env and fill in the values

# From Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=760020007329-329uni070n7doqke2b33q011la177lor.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here
# Full URL of your deployed server + /auth/callback
GOOGLE_REDIRECT_URI=https://your-app.onrender.com/auth/callback

# Set this after first sign-in (shown on the /auth/setup-done page)
GOOGLE_REFRESH_TOKEN=

# Any long random string — used to sign sessions
SESSION_SECRET=change-this-to-something-random

NODE_ENV=production
